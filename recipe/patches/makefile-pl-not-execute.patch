Under conda-build, expat is installed under $PREFIX but bundled Devel::CheckLib can
still fail its compile/link/run probe. Short-circuit when expat.h and libexpat are
present at EXPAT* paths; otherwise keep check_lib with not_execute and conda flags.

--- a/Makefile.PL
+++ b/Makefile.PL
@@ -81,12 +81,29 @@
     }
 }
 
+# Under conda-build, expat is in $PREFIX but bundled Devel::CheckLib often fails to
+# compile/link/run its probe (Perl Config vs toolchain, stripped LDFLAGS, etc.). Accept
+# expat when headers and libs are present at EXPAT* paths; otherwise fall back to check_lib.
+my $have_expat_in_prefix =
+      $expat_incpath
+    && $expat_libpath
+    && -f File::Spec->catfile( $expat_incpath, 'expat.h' )
+    && (
+           scalar( glob( File::Spec->catfile( $expat_libpath, 'libexpat.so*' ) ) )
+        || scalar( glob( File::Spec->catfile( $expat_libpath, 'libexpat*.dylib' ) ) )
+        || -f File::Spec->catfile( $expat_libpath, 'libexpat.a' )
+    );
+
 unless (
-    check_lib(    # fill in what you prompted the user for here
+       $have_expat_in_prefix
+    || check_lib(
         lib     => [qw(expat)],
         header  => ['expat.h'],
         incpath => $expat_incpath,
         ( $expat_libpath ? ( libpath => $expat_libpath ) : () ),
+        not_execute => 1,
+        ccflags => join( q{ }, grep { length } ( $ENV{CPPFLAGS} || q{} ), ( $ENV{CFLAGS} || q{} ) ),
+        ldflags => $ENV{LDFLAGS} || q{},
     )
 ) {
     warn <<'Expat_Not_Installed;';
